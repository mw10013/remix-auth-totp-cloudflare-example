{
  "name": "remix-auth-totp-cloudflare-example",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "remix build",
    "dev": "remix dev --manual -c \"npm run start\"",
    "lint": "eslint --ignore-path .gitignore --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "wrangler pages dev --compatibility-date=2023-12-01 ./public --kv=KV --d1=DB",
    "typecheck": "tsc",
    "tail:prod": "wrangler pages deployment tail --project-name remix-auth-totp-cloudflare-example --environment production",
    "tail:preview": "wrangler pages deployment tail --project-name remix-auth-totp-cloudflare-example --environment preview",
    "tail:deploy": "wrangler pages deployment tail --project-name remix-auth-totp-cloudflare-example",
    "tunnel": "cloudflared tunnel --url http://localhost:8788",
    "drizzle:generate": "drizzle-kit generate:sqlite",
    "drizzle:up": "drizzle-kit up:sqlite",
    "drizzle:check": "drizzle-kit check:sqlite",
    "drizzle:drop": "drizzle-kit drop",
    "d1:migrate:list": "wrangler d1 migrations list ratce-db-dev --local",
    "d1:migrate:apply": "wrangler d1 migrations apply ratce-db-dev --local",
    "d1:migrate:list:preview": "wrangler d1 migrations list ratce-db-preview --env preview",
    "d1:migrate:apply:preview": "wrangler d1 migrations apply ratce-db-preview --env preview",
    "d1:migrate:list:prod": "wrangler d1 migrations list ratce-db-prod --env prod",
    "d1:migrate:apply:prod": "wrangler d1 migrations apply ratce-db-prod --env prod",
    "d1:reset": "tsx scripts/d1-reset.ts",
    "d1:push": "tsx scripts/d1-push.ts",
    "script": "tsx --env-file=.dev.vars"
  },
  "dependencies": {
    "@nextui-org/react": "^2.2.9",
    "@remix-run/cloudflare": "^2.4.0",
    "@remix-run/cloudflare-pages": "^2.4.0",
    "@remix-run/css-bundle": "^2.4.0",
    "@remix-run/react": "^2.4.0",
    "drizzle-orm": "^0.29.1",
    "framer-motion": "^10.16.16",
    "isbot": "^3.6.8",
    "nanoid": "^5.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remix-auth": "^3.6.0",
    "remix-auth-totp": "^1.4.1",
    "tiny-invariant": "^1.3.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20231218.0",
    "@remix-run/dev": "^2.4.0",
    "@types/react": "^18.2.20",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "better-sqlite3": "^9.2.2",
    "drizzle-kit": "^0.20.6",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsx-a11y": "^6.7.1",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "3.0.3",
    "prettier-plugin-tailwindcss": "^0.5.9",
    "tailwindcss": "^3.3.6",
    "tsx": "^4.6.2",
    "typescript": "^5.1.0",
    "wrangler": "3.22.1",
    "zx": "^7.2.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
